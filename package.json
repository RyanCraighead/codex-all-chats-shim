{
  "name": "codex-all-chats-shim",
  "version": "0.1.0",
  "description": "Load the complete local task catalog in the normal Codex desktop app without patching the signed application.",
  "license": "MIT",
  "author": "Ryan Craighead",
  "repository": {
    "type": "git",
    "url": "https://github.com/RyanCraighead/codex-all-chats-shim.git"
  },
  "keywords": [
    "codex",
    "openai",
    "desktop",
    "chat-history",
    "interoperability"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "setup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "launch": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/launch-codex.ps1",
    "queue": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/queue-relaunch.ps1",
    "shortcut": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/create-shortcut.ps1",
    "shim": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/start-shim.ps1",
    "test": "node --test test/shim.test.cjs && node test/real-pagination-smoke.cjs --self-test",
    "test:live": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-test.ps1",
    "test:candidate": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/ci/validate-codex-candidate.ps1",
    "test:pipeline": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File test/release-pipeline-smoke.ps1",
    "check": "node --check src/catalog-shim.cjs && node --check test/real-pagination-smoke.cjs && npm test && npm run test:pipeline"
  },
  "dependencies": {
    "ws": "8.21.0"
  }
}
